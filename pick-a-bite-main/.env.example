# ─────────────────────────────────────────────
# Pick A Bite — Frontend Environment (ORNEK / SABLON)
# Bu dosyayi ayni klasorde ".env" olarak KOPYALA ve degerleri doldur.
# GERCEK ".env" dosyasi GitHub'a YUKLENMEZ (.gitignore icinde) — guvenlik.
# ─────────────────────────────────────────────

# Groq API — Chatbot (ZORUNLU). Ucretsiz anahtar: https://console.groq.com/keys
# Hem EXPO_PUBLIC_ (mobil uygulama) hem normal isim (test scriptleri) gerekli.
EXPO_PUBLIC_GROQ_API_KEY=buraya_groq_anahtarini_yaz
GROQ_API_KEY=buraya_groq_anahtarini_yaz

# Gemini API — opsiyonel yedek. Anahtar: https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=buraya_gemini_anahtarini_yaz
GEMINI_API_KEY=buraya_gemini_anahtarini_yaz

# Backend URL — "demo-baslat.bat" bu satiri Cloudflare tunnel adresiyle
# OTOMATIK gunceller. Elle baslatacaksan asagidaki localhost degerini birak.
EXPO_PUBLIC_BACKEND_URL=http://localhost:8080/pick-a-bite
